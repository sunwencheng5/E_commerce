<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lwzy.mapper.before.BuserMapper">
    <!--定义busertable和实体类Buser的映射关系-->
    <resultMap id="userMap" type="Buser">
        <id property="id" column="id"/>
        <result property="bemail" column="bemail"/>
        <result property="bpwd" column="bpwd"/>
    </resultMap>

    <select id="selectBuserByEmail" resultMap="userMap">
        select *
        from busertable
        where bemail=#{bemail}
    </select>

    <insert id="register">
        insert into busertable
        values(null,#{bemail},#{bpwd})
    </insert>

    <select id="selectBuser" resultMap="userMap">
        select *
        from busertable
        where bemail=#{bemail} and bpwd=#{bpwd}
    </select>
    
    <update id="updatebpwd">
        update busertable
        set bpwd = #{bwp}
        where id = #{id}
    </update>
</mapper>