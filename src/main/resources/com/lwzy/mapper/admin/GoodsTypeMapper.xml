<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lwzy.mapper.admin.GoodsTypeMapper">
    <!--定义goodstype表和实体类GoodsType的映射关系-->
    <resultMap id="GoodsTypeMap" type="GoodsType">
        <id property="id" column="id"/>
        <result property="typename" column="typename"/>
    </resultMap>

    <select id="selectAllGoodsType" resultMap="GoodsTypeMap">
        select *
        from goodstype
    </select>
    <update id="add">
        insert into goodstype values(null,#{typename})
    </update>
    <update id="update">
        update goodstype set typename=#{typename}
        where id=#{id}
    </update>
    <delete id="delete">
        delete from goodstype
        where id=#{id}
    </delete>
    <select id="selectByPage" resultMap="GoodsTypeMap">
        select *
        from goodstype
        order by id desc
        limit #{startIndex},#{pageSize}
    </select>
    <select id="selectAGoodsType" resultMap="GoodsTypeMap">
        select *
        from goodstype
        where id=#{id}
    </select>
</mapper>